model MedicalReport {
    id String @id @default(uuid(7))

    diagnosis    String?
    treatment    String?
    followUpDate DateTime?
    createdAt    DateTime  @default(now())
    updatedAt    DateTime  @updatedAt
    reportLink   String
    reportName   String

    // Relations
    patientId String
    patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

    @@index([patientId], name: "idx_medical_reports_patientId")
    @@map("medical_reports")
}
