<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Redirecting to Google...</title>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; color: #0f172a; }
        .card { text-align: center; background: white; padding: 40px; border-radius: 20px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
        .spinner { border: 3px solid #e2e8f0; border-top: 3px solid #38bdf8; border-radius: 50%; width: 30px; height: 30px; animation: spin 1s linear infinite; margin: 0 auto 20px; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <div class="card">
        <div class="spinner"></div>
        <p>Redirecting to Google...</p>
    </div>

    <script>
        (async () => {
            try {
                const response = await fetch("<%= betterAuthUrl %>/api/auth/sign-in/social", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    // MANDATORY: Tells the browser to save the 'state' cookie from the response
                    credentials: "include", 
                    body: JSON.stringify({
                        provider: "google",
                        callbackURL: "<%= callbackURL %>"
                    })
                });

                const data = await response.json();

                if (data.url) {
                    // We add a 150ms delay. 
                    // This gives the browser's cookie manager time to write the 
                    // Better-Auth state to local storage before the page unloads.
                    setTimeout(() => {
                        window.location.href = data.url;
                    }, 150);
                } else {
                    throw new Error("No URL returned from Auth server");
                }
            } catch (error) {
                document.querySelector('p').innerHTML = `
                    <span style="color: #ef4444;">Handshake Failed</span><br/>
                    <small>${error.message}</small>
                `;
            }
        })();
    </script>
</body>
</html>