<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Redirecting to Google...</title>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; color: #0f172a; }
        .card { text-align: center; background: white; padding: 40px; border-radius: 20px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
        .spinner { border: 3px solid #e2e8f0; border-top: 3px solid #38bdf8; border-radius: 50%; width: 30px; height: 30px; animation: spin 1s linear infinite; margin: 0 auto 20px; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <div class="card">
        <div class="spinner"></div>
        <p>Redirecting to Google...</p>
    </div>

    <script>
        (async () => {
            try {
                const response = await fetch("<%= betterAuthUrl %>/api/auth/sign-in/social", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    // This tells the browser to store the cookies the server sends back
                    credentials: "include", 
                    body: JSON.stringify({
                        provider: "google",
                        callbackURL: "<%= callbackURL %>"
                    })
                });

                if (!response.ok) {
                    const errorData = await response.json();
                    throw new Error(errorData.message || "Auth server error");
                }

                const data = await response.json();

                if (data.url) {
                    // We use replace() instead of href to avoid back-button loops
                    // and a tiny delay to ensure the browser saves the 'state' cookie
                    setTimeout(() => {
                        window.location.replace(data.url);
                    }, 150); 
                } else {
                    throw new Error("No redirect URL received");
                }
            } catch (error) {
                console.error("OAuth Error:", error);
                document.querySelector('p').innerHTML = `
                    <span style="color: #ef4444; font-weight: 600;">Login Failed</span><br/>
                    <small style="color: #64748b;">${error.message}</small><br/>
                    <button onclick="window.location.reload()" style="margin-top:10px; cursor:pointer;">Retry</button>
                `;
            }
        })();
    </script>
</body>
</html>