<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Prescription - PH Healthcare</title>
</head>

<body style="margin:0;padding:0;background-color:#1a202c;font-family:Arial,Helvetica,sans-serif;line-height:1.6;">

  <table width="100%" cellpadding="0" cellspacing="0" style="padding:40px 0;background-color:#1a202c;">
    <tr>
      <td align="center">

        <!-- Container -->
        <table width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff;border-radius:12px;overflow:hidden;">

          <!-- Header -->
          <tr>
            <td align="center" style="background-color:#2c3e50;padding:40px 20px;color:#ffffff;">
              <h1 style="margin:0 0 8px 0;font-size:24px;letter-spacing:2px;text-transform:uppercase;color:#48bb78;">
                Prescription
              </h1>
              <p style="margin:0;font-size:13px;color:#cbd5e0;font-weight:300;">
                PH HEALTHCARE DIGITAL SYSTEMS
              </p>
            </td>
          </tr>

          <!-- Main Body -->
          <tr>
            <td style="padding:40px;">

              <!-- Greeting -->
              <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:30px;">
                <tr>
                  <td style="border-left:4px solid #48bb78;padding-left:15px;">
                    <p style="margin:0 0 6px 0;font-size:16px;color:#2d3748;">
                      Dear <strong><%= patientName %></strong>,
                    </p>
                    <p style="margin:0;font-size:14px;color:#4a5568;">
                      Your digital prescription record has been successfully generated.
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Clinical Information -->
              <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:30px;">
                <tr>
                  <td style="padding-bottom:12px;font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:1px;color:#2c3e50;">
                    Clinical Information
                  </td>
                </tr>
                <tr>
                  <td style="background-color:#f8fafc;border:1px solid #e2e8f0;padding:20px;border-radius:8px;">

                    <table width="100%" cellpadding="0" cellspacing="0">

                      <tr>
                        <td style="padding-bottom:8px;font-size:14px;color:#718096;font-weight:500;">
                          Doctor
                        </td>
                        <td align="right" style="padding-bottom:8px;font-size:14px;color:#2d3748;font-weight:600;">
                          Dr. <%= doctorName %>
                        </td>
                      </tr>

                      <tr>
                        <td style="padding-bottom:8px;font-size:14px;color:#718096;font-weight:500;">
                          Specialization
                        </td>
                        <td align="right" style="padding-bottom:8px;font-size:14px;color:#2d3748;font-weight:600;">
                          <%= specialization %>
                        </td>
                      </tr>

                      <tr>
                        <td style="padding-bottom:8px;font-size:14px;color:#718096;font-weight:500;">
                          Issued Date
                        </td>
                        <td align="right" style="padding-bottom:8px;font-size:14px;color:#2d3748;font-weight:600;">
                          <%= issuedDate %>
                        </td>
                      </tr>

                      <% if (followUpDate) { %>
                      <tr>
                        <td style="font-size:14px;color:#718096;font-weight:500;">
                          Follow-up
                        </td>
                        <td align="right" style="font-size:14px;color:#38a169;font-weight:600;">
                          <%= followUpDate %>
                        </td>
                      </tr>
                      <% } %>

                    </table>

                  </td>
                </tr>
              </table>

              <!-- Instructions Section -->
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="padding-bottom:12px;font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:1px;color:#2c3e50;">
                    Instructions & Dosage
                  </td>
                </tr>
                <tr>
                  <td style="background-color:#f0fff4;border:1px solid #c6f6d5;padding:25px;border-radius:8px;">
                    <div style="color:#22543d;font-size:14px;line-height:1.8;white-space:pre-wrap;">
                      <%= instructions %>
                    </div>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Action Area -->
          <tr>
            <td align="center" style="padding:30px;background-color:#f7fafc;border-top:1px solid #edf2f7;">

              <p style="margin:0 0 15px 0;font-size:13px;color:#718096;">
                A secure PDF copy is attached. You may also access it online:
              </p>

              <% if (pdfUrl) { %>
              <a href="<%= pdfUrl %>"
                 style="display:inline-block;background-color:#2c3e50;color:#ffffff;text-decoration:none;padding:14px 35px;border-radius:6px;font-weight:bold;font-size:14px;">
                ACCESS SECURE PDF
              </a>
              <% } %>

              <!-- Security Notice -->
              <table width="100%" cellpadding="0" cellspacing="0" style="margin-top:20px;">
                <tr>
                  <td style="padding:15px;background-color:#fff5f5;border:1px solid #fed7d7;border-radius:6px;">
                    <p style="margin:0;font-size:12px;color:#c53030;text-align:center;">
                      <strong>SECURITY NOTICE:</strong> This document contains sensitive medical information. Please handle with care.
                    </p>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="padding:30px;background-color:#ffffff;color:#a0aec0;font-size:11px;">
              <p style="margin:0;">
                © 2026 PH Healthcare Services. All Rights Reserved.
              </p>
              <p style="margin:5px 0 0 0;">
                This is a system-generated message. Please do not reply.
              </p>
            </td>
          </tr>

        </table>
        <!-- End Container -->

      </td>
    </tr>
  </table>

</body>
</html>